{
  "name": "e2ee-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm": "wasm-pack build wasm --target web --out-dir ../src/wasm --no-pack",
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run wasm && npm run typecheck && npm test",
    "build": "npm run wasm && npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "vite": "^8.0.13"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.6",
    "wasm-pack": "^0.15.0"
  }
}
